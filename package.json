{
  "name": "suspec-website-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/ensure-canon.mjs",
    "prebuild": "node scripts/ensure-canon.mjs",
    "build": "next build",
    "postbuild": "pagefind --site dist --output-subdir pagefind",
    "audit:copy": "node scripts/audit-copy.mjs",
    "audit:css": "node scripts/audit-css.mjs && npm run audit:palette && npm run audit:tokens",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "audit:palette": "node scripts/audit-palette.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:site": "node scripts/audit-site.mjs",
    "audit:visual": "node scripts/audit-visual.mjs",
    "audit:axe": "node scripts/audit-axe.mjs",
    "audit:keyboard": "node scripts/audit-keyboard.mjs",
    "audit:contrast": "node scripts/audit-contrast.mjs",
    "audit:a11y": "npm run audit:axe && npm run audit:keyboard && npm run audit:contrast",
    "audit:ssr": "node scripts/audit-ssr.mjs",
    "audit:perf": "node scripts/audit-performance.mjs",
    "audit:goal": "npm run build && npm run audit:copy && npm run audit:css && npm run audit:links && npm run audit:site && npm run audit:visual && npm run audit:a11y && npm run audit:ssr && npm run audit:perf",
    "start": "serve dist",
    "lint": "eslint"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "pagefind": "^1.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "unist-util-visit-parents": "^6.0.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@tailwindcss/postcss": "^4",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unist": "^3.0.3",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "lighthouse": "^12.8.2",
    "linkinator": "^7.6.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^5",
    "ws": "^8.21.0"
  }
}
